<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div id="cursor"></div><div id="cursor-ring"></div>
<%- include('../partials/navbar') %>

<div class="page-hero">
  <div class="page-hero-bg"></div><div class="grid-bg"></div>
  <div class="page-hero-content">
    <span class="page-tag">Services</span>
    <h1>Our <span>Washes</span></h1>
    <p>From a quick refresh to a complete premium detail — every tier is engineered for perfection.</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="reveal" style="margin-bottom:3rem;">
      <span class="section-label">Choose Your Wash</span>
      <h2 class="section-title">Find the Perfect <span>Clean</span></h2>
    </div>
    <div class="wash-cards">
      <div class="wash-card c1 reveal">
        <div class="wash-price">₦10,800</div>
        <div class="wash-name">BASIC WASH</div>
        <ul class="wash-includes">
          <li>Full exterior rinse</li>
          <li>Foam pre-soak</li>
          <li>High-pressure wash</li>
          <li>Spot-free rinse</li>
          <li>Air dry</li>
          <li>Complimentary turbo vacs</li>
        </ul>
        <button class="wash-cta">Get Basic Wash</button>
      </div>
      <div class="wash-card c2 reveal" style="border-color:var(--cyan);border-width:2px;">
        <div style="position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:rgba(0,85,221,0.2);border:1px solid var(--cyan);padding:0.3rem 1rem;border-radius:4px;font-family:Orbitron,monospace;font-size:0.65rem;color:var(--cyan);letter-spacing:1px;text-transform:uppercase;">Popular</div>
        <div class="wash-price">₦16,800</div>
        <div class="wash-name">DELUXE WASH</div>
        <ul class="wash-includes">
          <li>Everything in Basic</li>
          <li>Triple-foam conditioner</li>
          <li>Wheel blast treatment</li>
          <li>Tire shine application</li>
          <li>Rust inhibitor rinse</li>
        </ul>
        <button class="wash-cta">Get Deluxe Wash</button>
      </div>
      <div class="wash-card c3 reveal">
        <div class="wash-price">₦22,800</div>
        <div class="wash-name">PREMIUM WASH</div>
        <ul class="wash-includes">
          <li>Everything in Deluxe</li>
          <li>Rain-X® sealant coating</li>
          <li>Ceramic gloss protectant</li>
          <li>Interior surface spray</li>
          <li>Air freshener</li>
        </ul>
        <button class="wash-cta">Get Premium Wash</button>
      </div>
      <div class="wash-card c4 reveal">
        <div class="wash-price">₦34,800</div>
        <div class="wash-name">PREMIER WASH</div>
        <ul class="wash-includes">
          <li>Everything in Premium</li>
          <li>Graphene ceramic shield</li>
          <li>Full underbody flush</li>
          <li>Engine bay rinse</li>
          <li>Premium air freshener</li>
        </ul>
        <button class="wash-cta">Get Premier Wash</button>
      </div>
    </div>
  </div>
</section>

<section class="section" style="border-top:1px solid var(--border);">
  <div class="container">
    <div style="background:linear-gradient(135deg,rgba(0,85,221,0.1),rgba(0,245,255,0.04));border:1px solid var(--border);padding:4rem;text-align:center;" class="reveal">
      <span class="section-label">Save More</span>
      <h2 class="section-title" style="text-align:center;">Wash More, <span>Pay Less</span></h2>
      <p style="font-size:1rem;color:var(--text);max-width:520px;margin:0 auto 2.5rem;line-height:1.75;">Subscribe to AURA Unlimited® and get unlimited washes starting at ₦22,800/month. Members save up to 60%.</p>
      <a href="/memberships" class="btn-primary">View Membership Plans →</a>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
