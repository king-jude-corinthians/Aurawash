<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<%- include('../partials/admin-sidebar') %>
<div style="padding:2rem;max-width:1400px;">
  <h1 style="color:white;font-family:'Orbitron',monospace;margin-bottom:2rem;">📊 Dashboard</h1>
  
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.5rem;margin-bottom:3rem;">
    <div style="background:rgba(0,85,221,0.1);border:1px solid var(--border);border-left:3px solid var(--blue);padding:1.5rem;border-radius:8px;">
      <div style="font-size:0.8rem;color:var(--text);letter-spacing:1px;text-transform:uppercase;margin-bottom:0.5rem;">Total Signups</div>
      <div style="font-family:'Orbitron',monospace;font-size:2rem;font-weight:900;color:var(--cyan);"><%= totalSignups %></div>
      <a href="/admin/signups" style="font-size:0.8rem;color:var(--cyan);text-decoration:none;margin-top:0.5rem;display:inline-block;">View all →</a>
    </div>
    
    <div style="background:rgba(255,200,87,0.1);border:1px solid var(--border);border-left:3px solid #ffc857;padding:1.5rem;border-radius:8px;">
      <div style="font-size:0.8rem;color:var(--text);letter-spacing:1px;text-transform:uppercase;margin-bottom:0.5rem;">New Signups</div>
      <div style="font-family:'Orbitron',monospace;font-size:2rem;font-weight:900;color:#ffc857;"><%= newSignups %></div>
      <a href="/admin/signups" style="font-size:0.8rem;color:#ffc857;text-decoration:none;margin-top:0.5rem;display:inline-block;">View pending →</a>
    </div>
    
    <div style="background:rgba(0,245,255,0.08);border:1px solid var(--border);border-left:3px solid var(--cyan);padding:1.5rem;border-radius:8px;">
      <div style="font-size:0.8rem;color:var(--text);letter-spacing:1px;text-transform:uppercase;margin-bottom:0.5rem;">Total Contacts</div>
      <div style="font-family:'Orbitron',monospace;font-size:2rem;font-weight:900;color:var(--cyan);"><%= totalContacts %></div>
      <a href="/admin/contacts" style="font-size:0.8rem;color:var(--cyan);text-decoration:none;margin-top:0.5rem;display:inline-block;">View all →</a>
    </div>
    
    <div style="background:rgba(244,67,54,0.1);border:1px solid var(--border);border-left:3px solid #f44336;padding:1.5rem;border-radius:8px;">
      <div style="font-size:0.8rem;color:var(--text);letter-spacing:1px;text-transform:uppercase;margin-bottom:0.5rem;">Unread Messages</div>
      <div style="font-family:'Orbitron',monospace;font-size:2rem;font-weight:900;color:#f44336;"><%= unreadContacts %></div>
      <a href="/admin/contacts" style="font-size:0.8rem;color:#f44336;text-decoration:none;margin-top:0.5rem;display:inline-block;">Respond now →</a>
    </div>
  </div>

  <div style="background:rgba(10,10,22,0.6);border:1px solid var(--border);padding:2rem;border-radius:8px;">
    <h2 style="color:white;font-family:'Orbitron',monospace;margin-bottom:1rem;">Quick Actions</h2>
    <div style="display:flex;gap:1rem;flex-wrap:wrap;">
      <a href="/admin/signups" style="padding:0.7rem 1.2rem;background:var(--blue);color:white;text-decoration:none;border-radius:6px;font-size:0.85rem;font-weight:700;">📋 View All Signups</a>
      <a href="/admin/contacts" style="padding:0.7rem 1.2rem;background:var(--cyan);color:var(--dark);text-decoration:none;border-radius:6px;font-size:0.85rem;font-weight:700;">📧 View Messages</a>
      <a href="/admin/logout" style="padding:0.7rem 1.2rem;background:#f44336;color:white;text-decoration:none;border-radius:6px;font-size:0.85rem;font-weight:700;">🚪 Logout</a>
    </div>
  </div>
</div>
</body>
</html>
