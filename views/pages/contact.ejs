<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
.contact-grid { display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:start; }
.form-group { margin-bottom:1.2rem; }
.form-group label { display:block; font-family:'Orbitron',monospace; font-size:0.65rem; letter-spacing:2px; color:var(--cyan); text-transform:uppercase; margin-bottom:0.5rem; }
.form-group input,.form-group textarea,.form-group select { width:100%; background:rgba(0,0,0,0.4); border:1px solid rgba(0,245,255,0.15); color:white; padding:0.8rem 1rem; font-family:'Rajdhani',sans-serif; font-size:0.95rem; outline:none; transition:border-color 0.3s; }
.form-group input:focus,.form-group textarea:focus,.form-group select:focus { border-color:rgba(0,245,255,0.5); }
.form-group textarea { resize:vertical; min-height:120px; }
.submit-btn { width:100%; padding:0.9rem; background:linear-gradient(135deg,var(--blue),var(--cyan)); border:none; color:var(--dark); font-family:'Orbitron',monospace; font-size:0.65rem; letter-spacing:2px; text-transform:uppercase; font-weight:700; cursor:pointer; }
.info-label { font-family:'Orbitron',monospace; font-size:0.65rem; letter-spacing:3px; color:var(--cyan); text-transform:uppercase; margin-bottom:0.4rem; display:block; }
.info-value { font-size:1rem; color:var(--text2); }
.success-msg,.error-msg { padding:1rem; border-radius:6px; margin-bottom:1rem; font-size:0.95rem; }
.success-msg { background:rgba(76,175,80,0.1); border:1px solid rgba(76,175,80,0.3); color:rgb(76,175,80); }
.error-msg { background:rgba(244,67,54,0.1); border:1px solid rgba(244,67,54,0.3); color:rgb(244,67,54); }
@media(max-width:900px) { .contact-grid { grid-template-columns:1fr; } }
  </style>
</head>
<body>
<div id="cursor"></div><div id="cursor-ring"></div>
<%- include('../partials/navbar') %>

<div class="page-hero">
  <div class="page-hero-bg"></div><div class="grid-bg"></div>
  <div class="page-hero-content">
    <span class="page-tag">Get In Touch</span>
    <h1>Contact <span>AURA WASH</span></h1>
    <p>Have a question? We'd love to hear from you. Reach out anytime.</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info reveal">
        <h2 style="color:white;margin-bottom:2rem;font-family:Orbitron,monospace;">Contact Information</h2>
        <div style="margin-bottom:2rem;">
          <span class="info-label">📞 Phone</span>
          <div class="info-value">+234 (0) 700-AURA-WASH<br/>+234 (0) 700-2872</div>
        </div>
        <div style="margin-bottom:2rem;">
          <span class="info-label">📧 Email</span>
          <div class="info-value">support@aurawash.com<br/>hello@aurawash.com</div>
        </div>
        <div style="margin-bottom:2rem;">
          <span class="info-label">🏢 Headquarters</span>
          <div class="info-value">AURA WASH HQ<br/>Lagos<br/>Nigeria</div>
        </div>
        <div style="margin-bottom:2rem;">
          <span class="info-label">🕐 Hours</span>
          <div class="info-value">Monday - Friday: 9am - 6pm<br/>Saturday: 10am - 4pm<br/>Sunday: Closed</div>
        </div>
      </div>

      <form style="background:rgba(10,10,22,0.7);border:1px solid var(--border);padding:2rem;" class="reveal">
        <h2 style="color:white;margin-bottom:1.5rem;font-family:Orbitron,monospace;">Send Message</h2>
        <% if (success) { %>
          <div class="success-msg">✓ Thank you! We'll be in touch soon.</div>
        <% } %>
        <% if (error) { %>
          <div class="error-msg">✗ Error sending message. Please try again.</div>
        <% } %>
        <form method="POST" action="/contact">
          <div class="form-group">
            <label>Name</label>
            <input type="text" name="name" placeholder="Your full name" required />
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" placeholder="you@example.com" required />
          </div>
          <div class="form-group">
            <label>Phone</label>
            <input type="tel" name="phone" placeholder="Your phone number" />
          </div>
          <div class="form-group">
            <label>Subject</label>
            <select name="subject" required>
              <option value="">Select a subject</option>
              <option>General Inquiry</option>
              <option>Support Request</option>
              <option>Business Partnership</option>
              <option>Feedback</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label>Message</label>
            <textarea name="message" placeholder="Your message..." required></textarea>
          </div>
          <button type="submit" class="submit-btn">Send Message</button>
          <p style="font-size:0.85rem;color:var(--text);margin-top:1rem;">We'll respond within 24 hours.</p>
        </form>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
