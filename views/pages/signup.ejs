<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
.panel { background:var(--panel);border:1px solid var(--border);padding:3rem;margin:3rem auto;max-width:700px; }
.form-group { margin-bottom:1.5rem; }
.form-group label { display:block;color:var(--cyan);font-family:Orbitron,monospace;font-size:0.7rem;letter-spacing:1px;text-transform:uppercase;margin-bottom:0.6rem; }
.form-group input,.form-group select { width:100%;padding:0.9rem;border:1px solid rgba(0,245,255,0.08);background:transparent;color:white;font-family:Rajdhani,sans-serif; outline:none;transition:border-color 0.3s; }
.form-group input:focus,.form-group select:focus { border-color:rgba(0,245,255,0.5); }
.btn { display:inline-block;padding:0.9rem 1.6rem;background:linear-gradient(135deg,var(--blue),var(--cyan));color:var(--dark);border:none;border-radius:6px;cursor:pointer;font-weight:700;font-family:Orbitron,monospace;font-size:0.75rem;letter-spacing:1.5px;text-transform:uppercase; }
.alert { background:rgba(255,0,0,0.06);border:1px solid rgba(255,0,0,0.12);padding:1rem;border-radius:6px;color:var(--text);margin-bottom:1rem;text-align:center; }
.success-msg { background:rgba(76,175,80,0.1);border:1px solid rgba(76,175,80,0.3);color:rgb(76,175,80); }
  </style>
</head>
<body>
<div id="cursor"></div><div id="cursor-ring"></div>
<%- include('../partials/navbar') %>

<div class="panel">
  <h2 style="font-family:Orbitron,monospace;color:white;margin-bottom:0.5rem;text-align:center;font-size:1.6rem;">Join AURA WASH</h2>
  <p style="color:var(--text);margin-bottom:2rem;text-align:center;">Sign up to get exclusive member benefits and stay updated on new washes.</p>
  
  <% if (success) { %>
    <div class="alert success-msg">✓ Thanks for signing up! We'll be in touch soon.</div>
  <% } %>
  <% if (error) { %>
    <div class="alert">✗ Error during signup. Please try again.</div>
  <% } %>

  <form method="POST" action="/signup">
    <div class="form-group">
      <label>First Name</label>
      <input type="text" name="firstName" placeholder="Your first name" required />
    </div>
    <div class="form-group">
      <label>Last Name</label>
      <input type="text" name="lastName" placeholder="Your last name" required />
    </div>
    <div class="form-group">
      <label>Email</label>
      <input type="email" name="email" placeholder="you@example.com" required />
    </div>
    <div class="form-group">
      <label>Phone</label>
      <input type="tel" name="phone" placeholder="Your phone number" />
    </div>
    <div class="form-group">
      <label>Interested Plan</label>
      <select name="plan">
        <option value="">Select a plan (optional)</option>
        <option value="basic">Basic Pass</option>
        <option value="pro">Pro Pass</option>
        <option value="elite">Elite Pass</option>
      </select>
    </div>
    <button type="submit" class="btn" style="width:100%;">Create Account</button>
  </form>
  
  <p style="color:var(--text);margin-top:1.5rem;text-align:center;font-size:0.9rem;">Already a member? <a href="/" style="color:var(--cyan);text-decoration:none;">Go home</a></p>
</div>

<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
