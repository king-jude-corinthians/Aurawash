<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--dark);">
  <div style="background:rgba(10,10,20,0.9);border:1px solid var(--border);padding:3rem;max-width:420px;width:100%;border-radius:12px;">
    <div style="text-align:center;margin-bottom:2rem;">
      <div style="font-family:'Orbitron',monospace;font-size:1.6rem;font-weight:900;color:white;margin-bottom:0.5rem;">
        <em style="color:var(--cyan);text-shadow:0 0 16px var(--cyan);">AURA</em>WASH
      </div>
      <div style="font-size:0.8rem;color:var(--text);letter-spacing:2px;text-transform:uppercase;">Admin Panel</div>
    </div>

    <% if (error) { %>
      <div style="background:rgba(244,67,54,0.1);border:1px solid rgba(244,67,54,0.3);color:rgb(244,67,54);padding:0.8rem;border-radius:6px;margin-bottom:1.5rem;font-size:0.9rem;text-align:center;">
        <%= error %>
      </div>
    <% } %>

    <form method="POST" action="/admin/login">
      <div style="margin-bottom:1.5rem;">
        <label style="display:block;font-family:'Orbitron',monospace;font-size:0.65rem;letter-spacing:2px;color:var(--cyan);text-transform:uppercase;margin-bottom:0.6rem;">Username</label>
        <input type="text" name="username" placeholder="admin" required style="width:100%;padding:0.8rem;border:1px solid rgba(0,245,255,0.15);background:rgba(0,0,0,0.4);color:white;font-family:Rajdhani,sans-serif;outline:none;transition:border-color 0.3s;" />
      </div>
      <div style="margin-bottom:2rem;">
        <label style="display:block;font-family:'Orbitron',monospace;font-size:0.65rem;letter-spacing:2px;color:var(--cyan);text-transform:uppercase;margin-bottom:0.6rem;">Password</label>
        <input type="password" name="password" placeholder="••••••••" required style="width:100%;padding:0.8rem;border:1px solid rgba(0,245,255,0.15);background:rgba(0,0,0,0.4);color:white;font-family:Rajdhani,sans-serif;outline:none;transition:border-color 0.3s;" />
      </div>
      <button type="submit" style="width:100%;padding:0.85rem;background:linear-gradient(135deg,var(--blue),var(--cyan));border:none;color:var(--dark);font-family:'Orbitron',monospace;font-size:0.7rem;letter-spacing:2px;text-transform:uppercase;font-weight:700;cursor:pointer;border-radius:6px;">Login</button>
    </form>

    <div style="text-align:center;margin-top:1.5rem;font-size:0.8rem;color:var(--text);">
      Default: <strong>admin / admin123</strong><br/>
      (Change after first login)
    </div>
  </div>
</div>
</body>
</html>
