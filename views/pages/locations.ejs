<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div id="cursor"></div><div id="cursor-ring"></div>
<%- include('../partials/navbar') %>
<div class="page-hero">
  <div class="page-hero-bg"></div><div class="grid-bg"></div>
  <div class="page-hero-content">
    <span class="page-tag">Find Us</span>
    <h1>Our <span>Locations</span></h1>
    <p>500+ locations across Nigeria and beyond.</p>
  </div>
</div>
<section class="section">
  <div class="container">
    <div class="reveal" style="margin-bottom:3rem;"><span class="section-label">Service Areas</span><h2 class="section-title">We're Growing <span>Fast</span></h2></div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1.5rem;">
      <div style="background:rgba(10,10,22,0.7);border:1px solid var(--border);padding:1.5rem;" class="reveal">
        <div style="font-family:'Orbitron',monospace;font-size:0.7rem;color:var(--cyan);letter-spacing:1px;margin-bottom:0.5rem;">LAGOS</div>
        <ul style="list-style:none;font-size:0.9rem;color:var(--text);line-height:1.8;">
          <li>🔹 Ikeja</li>
          <li>🔹 Lekki</li>
          <li>🔹 Victoria Island</li>
          <li>🔹 Surulere</li>
        </ul>
      </div>
      <div style="background:rgba(10,10,22,0.7);border:1px solid var(--border);padding:1.5rem;" class="reveal">
        <div style="font-family:'Orbitron',monospace;font-size:0.7rem;color:var(--cyan);letter-spacing:1px;margin-bottom:0.5rem;">FCT</div>
        <ul style="list-style:none;font-size:0.9rem;color:var(--text);line-height:1.8;">
          <li>🔹 Garki</li>
          <li>🔹 Wuse</li>
          <li>🔹 Asokoro</li>
        </ul>
      </div>
      <div style="background:rgba(10,10,22,0.7);border:1px solid var(--border);padding:1.5rem;" class="reveal">
        <div style="font-family:'Orbitron',monospace;font-size:0.7rem;color:var(--cyan);letter-spacing:1px;margin-bottom:0.5rem;">OTHER REGIONS</div>
        <ul style="list-style:none;font-size:0.9rem;color:var(--text);line-height:1.8;">
          <li>🔹 Port Harcourt</li>
          <li>🔹 Ibadan</li>
          <li>🔹 Kano</li>
          <li>🔹 And Growing...</li>
        </ul>
      </div>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
