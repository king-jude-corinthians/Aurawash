<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title><%= title %></title><link rel="stylesheet" href="/css/style.css"></head>
<body><div id="cursor"></div><div id="cursor-ring"></div>
<%- include('../partials/navbar') %>
<div class="page-hero"><div class="page-hero-bg"></div><div class="grid-bg"></div><div class="page-hero-content"><span class="page-tag">Perfect Gift</span><h1>AURA WASH <span>Gift Cards</span></h1><p>Give the gift of clean. Perfect for car lovers and busy professionals.</p></div></div>
<section class="section"><div class="container"><div class="reveal" style="text-align:center;margin-bottom:2rem;"><span class="section-label">Choose Amount</span><h2 class="section-title">Select Your <span>Gift Card</span></h2></div>
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.5rem;">
<div style="background:rgba(10,10,22,0.6);border:1px solid var(--border);padding:2rem;text-align:center;" class="reveal"><div style="font-size:2rem;margin-bottom:0.5rem;">🎁</div><h3 style="color:white;margin:0.5rem 0;font-family:Orbitron,monospace;">Starter</h3><div style="font-size:1.6rem;font-weight:900;color:var(--cyan);margin:1rem 0;">₦10,000</div><p style="font-size:0.85rem;color:var(--text);margin-bottom:1.5rem;">1 Premium Wash</p><button style="padding:0.6rem 1.2rem;background:var(--cyan);color:var(--dark);border:none;font-weight:700;cursor:pointer;width:100%;">Send Gift</button></div>
<div style="background:rgba(10,10,22,0.6);border:1px solid var(--border);padding:2rem;text-align:center;" class="reveal"><div style="font-size:2rem;margin-bottom:0.5rem;">🎉</div><h3 style="color:white;margin:0.5rem 0;font-family:Orbitron,monospace;">Popular</h3><div style="font-size:1.6rem;font-weight:900;color:var(--cyan);margin:1rem 0;">₦25,000</div><p style="font-size:0.85rem;color:var(--text);margin-bottom:1.5rem;">1 Month Pro</p><button style="padding:0.6rem 1.2rem;background:var(--cyan);color:var(--dark);border:none;font-weight:700;cursor:pointer;width:100%;">Send Gift</button></div>
<div style="background:rgba(10,10,22,0.6);border:1px solid var(--border);padding:2rem;text-align:center;" class="reveal"><div style="font-size:2rem;margin-bottom:0.5rem;">⭐</div><h3 style="color:white;margin:0.5rem 0;font-family:Orbitron,monospace;">Premium</h3><div style="font-size:1.6rem;font-weight:900;color:var(--cyan);margin:1rem 0;">₦50,000</div><p style="font-size:0.85rem;color:var(--text);margin-bottom:1.5rem;">2 Months Pro</p><button style="padding:0.6rem 1.2rem;background:var(--cyan);color:var(--dark);border:none;font-weight:700;cursor:pointer;width:100%;">Send Gift</button></div>
</div></div></section>
<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
</body></html>
